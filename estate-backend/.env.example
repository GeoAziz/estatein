NODE_ENV=development
PORT=3000

# Database
DATABASE_URL="postgresql://estate_dev:local_password@localhost:5432/estate_dev"

# JWT
JWT_SECRET="dev-secret-change-in-production"
JWT_REFRESH_SECRET="dev-refresh-secret-change-in-production"
JWT_EXPIRES_IN="24h"
JWT_REFRESH_EXPIRES_IN="7d"

# AWS/LocalStack
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local
AWS_ENDPOINT=http://localhost:4566
S3_BUCKET=estatein-images
SQS_QUEUE_URL=http://localhost:4566/000000000000/estatein-jobs

# Email (SendGrid)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS="your-sendgrid-api-key"
SMTP_FROM=noreply@estatein.local

# App
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# M-Pesa (Coming Soon)
MPESA_CONSUMER_KEY=""
MPESA_CONSUMER_SECRET=""
MPESA_SHORT_CODE="174379"
MPESA_PASSKEY=""
MPESA_CALLBACK_URL="https://api.estatein.local/api/payments/mpesa/callback"
# Random secret appended to the callback URL path; must match what's registered with Safaricom.
MPESA_CALLBACK_TOKEN=""
MPESA_ENABLED=false

# SMS Provider (Twilio - Coming Soon)
SMS_PROVIDER="twilio"
SMS_API_KEY=""
SMS_API_SECRET=""
SMS_SENDER_ID="ESTATEIN"
SMS_ENABLED=false

# Firebase Cloud Messaging (Push Notifications)
FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"real-estate-511c5",...}'

# Google Maps
GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Apple Sign-In (Coming Soon)
APPLE_CLIENT_ID=""
APPLE_TEAM_ID=""
APPLE_KEY_ID=""
APPLE_PRIVATE_KEY=""
APPLE_ENABLED=false

# Sentry (Error Tracking)
SENTRY_DSN="https://your-sentry-dsn"

# Redis (Local)
REDIS_URL="redis://localhost:6379"

# OpenSearch / Elasticsearch (Local)
OPENSEARCH_URL="http://localhost:9200"

# WebSocket
WS_CORS_ORIGIN="http://localhost:5173"
