# NgROK Environment Variables
# Copy to .env.ngrok and update with your ngrok URL
# Then: export $(cat .env.ngrok | xargs) && docker-compose up -d

# Your ngrok public URL (e.g., https://my-app.ngrok-free.dev)
NGROK_URL=https://your-ngrok-url.ngrok-free.dev

# These are derived from NGROK_URL:
FRONTEND_URL=${NGROK_URL}
VITE_API_URL=${NGROK_URL}/api

# Optional: set ngrok region (us, eu, au, jp, in, sa)
NGROK_REGION=us
