# Committed intentionally on the Demo branch only — no secrets here, just a
# public build flag. Vite loads this only for `vite build`/production mode
# (not `vite dev` or vitest's "test" mode), so it makes `npm run build` and
# the Vercel deployment of this branch use the backend-free demo mode
# (src/lib/demo/) automatically, without breaking local dev or unit tests.
# See app/.env.development for the equivalent in `npm run dev`.
VITE_DEMO_MODE=true
