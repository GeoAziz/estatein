VITE_API_URL=http://localhost:3000/api
VITE_APP_NAME=Estatein

# Set to "true" to build a fully static, backend-free demo (see
# src/lib/demo/) — used for the Demo branch's Vercel deployment. Leave unset
# or "false" for the real app talking to a live backend.
VITE_DEMO_MODE=false

# Google Maps
VITE_GOOGLE_MAPS_API_KEY=

# Sentry
VITE_SENTRY_DSN=
